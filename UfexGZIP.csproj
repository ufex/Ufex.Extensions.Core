<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
	<TargetFramework>net48</TargetFramework>
	<RootNamespace>Ufex.FileTypes</RootNamespace>
	<AssemblyName>GZIP</AssemblyName>
	<BaseOutputPath>bin\</BaseOutputPath>
	<AssemblyVersion>1.3.0.0</AssemblyVersion>
	<SignAssembly>False</SignAssembly>
	<Company>Edward Potocko</Company>
	<Product>Universal File Explorer</Product>
	<PackageReadmeFile>README.md</PackageReadmeFile>
	<RepositoryUrl>https://github.com/epotocko/UfexGZIP</RepositoryUrl>
	<RepositoryType>git</RepositoryType>
	<FileVersion>1.3.0.0</FileVersion>
	<Version>1.3.0.0</Version>
	<Copyright>Copyright (C) Eddie Potocko 2005 - 2021</Copyright>
  </PropertyGroup>
 
  <ItemGroup>
	<ProjectReference Include="..\..\ufex\UfexAPI\UfexAPI.csproj" />
  </ItemGroup>

  <ItemGroup>
	<Reference Include="System.Windows.Forms" />
  </ItemGroup>

	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Exec Command="copy $(TargetDir)\GZIP.dll $(SolutionDir)\x64\$(ConfigurationName)\modules\GZIP.dll" />
	</Target>

</Project>
