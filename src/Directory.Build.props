<Project>
  <!-- Common properties for all plugin projects in Ufex.Extensions.Core -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Company>Ufex</Company>
    <Product>Universal File Explorer</Product>
    <Copyright>Copyright (C) Ed Potocko 2005 - 2026</Copyright>
    <!-- Disable auto-generated assembly info to avoid conflicts with legacy AssemblyInfo.cs files -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <!-- Common project reference to Ufex.API -->
  <ItemGroup>
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\..\src\Ufex.API\Ufex.API.csproj" />
  </ItemGroup>

  <!-- Output all plugins to the Desktop app's plugins directory -->
  <PropertyGroup>
    <PluginOutputDir>$(MSBuildThisFileDirectory)..\..\..\src\Ufex.Desktop\bin\Debug\net10.0\plugins\</PluginOutputDir>
  </PropertyGroup>

  <!-- Copy plugin DLL to plugins directory after build -->
  <Target Name="CopyPluginToOutput" AfterTargets="Build">
    <MakeDir Directories="$(PluginOutputDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(PluginOutputDir)" SkipUnchangedFiles="true" />
  </Target>
</Project>
